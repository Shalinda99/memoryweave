# ============================================================
# MemoryWeave — Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub
# ============================================================

# ------------------------------------------------------------
# Qwen Cloud (Alibaba Cloud DashScope)
# Get your key at: https://dashscope.aliyuncs.com
# This is the ALIBABA CLOUD proof of integration
# ------------------------------------------------------------
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ------------------------------------------------------------
# Supabase (Free PostgreSQL)
# Sign up at: https://supabase.com (no credit card)
# Get from: Project Settings → API
# ------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# ------------------------------------------------------------
# Redis
# Local dev: redis://redis:6379 (docker-compose handles this)
# Production (Upstash): rediss://default:TOKEN@xxx.upstash.io:6380
# Sign up at: https://upstash.com (no credit card)
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# Qwen Model Selection (defaults are fine, do not change)
# ------------------------------------------------------------
QWEN_CHAT_MODEL=qwen-max
QWEN_LONG_MODEL=qwen-long
QWEN_EMBED_MODEL=text-embedding-v3
QWEN_FAST_MODEL=qwen-turbo

# ------------------------------------------------------------
# App Settings
# ------------------------------------------------------------
APP_ENV=development
# Add your Vercel URL here when deploying to production:
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
